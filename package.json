{
  "name": "valcrown",
  "version": "1.0.0",
  "description": "ValCrown — Windows Game Performance Optimizer",
  "main": "electron/main.js",
  "author": "XOGAMESLTD",
  "homepage": "https://valcrown.com",
  "scripts": {
    "start": "electron .",
    "dev":   "electron . --dev",
    "build": "electron-builder --win"
  },
  "dependencies": {
    "electron-store":   "^8.1.0",
    "node-machine-id":  "^1.1.12"
  },
  "devDependencies": {
    "electron":         "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "com.xogamesltd.valcrown",
    "productName": "ValCrown",
    "copyright":   "Copyright 2026 XOGAMESLTD",
    "files": ["electron/**/*","renderer/**/*","engines/**/*","package.json"],
    "win": {
      "icon": "renderer/src/assets/icon.png",
      "requestedExecutionLevel": "requireAdministrator",
      "target": [{"target":"nsis","arch":["x64"]}]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "ValCrown",
      "runAfterFinish": true
    },
    "publish": [{"provider":"github","owner":"xogamesltd","repo":"valcrown-app"}]
  }
}
