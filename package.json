{
  "name": "valcrown",
  "version": "1.0.27",
  "description": "ValCrown \u2014 Windows Game Performance Optimizer",
  "main": "electron/main.js",
  "author": "XOGAMESLTD",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build:win": "electron-builder --win"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.xogamesltd.valcrown",
    "productName": "ValCrown",
    "copyright": "Copyright 2026 XOGAMESLTD",
    "files": [
      "electron/**/*",
      "renderer/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "requireAdministrator",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ValCrown",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    }
  },
  "homepage": "https://valcrown.com"
}